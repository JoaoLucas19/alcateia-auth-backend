# Banco de dados MySQL (formato Prisma)
DATABASE_URL="mysql://usuario:senha@host:3306/nome_do_banco"

# JWT
JWT_SECRET="troque_por_um_secret_longo_e_aleatorio_de_64_chars"
JWT_EXPIRES_IN="8h"

# Servidor
PORT=3000
NODE_ENV="development"

# Origens extras no CORS (separadas por vírgula). Use * só em dev local.
# whitexcorporation.com.br (http/https) já está em src/config/cors.ts
ALLOWED_ORIGINS="http://localhost:5173,https://seudominio.com.br,http://seudominio.com.br"

# Senhas dos admins (usadas apenas no seed)
ADMIN_PASSWORD_1=senha-do-admin-1
ADMIN_PASSWORD_2=senha-do-admin-2

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Discord — alertas de segurança (cole a URL do webhook do seu servidor)
# NUNCA commite a URL real no Git. Configure no Railway → Variables.
DISCORD_WEBHOOK_URL=""
DISCORD_ALERTS_ENABLED=true
# Poller a cada 5 min; cooldown 15 min por alerta (evita spam)
DISCORD_ALERT_POLL_MS=300000
DISCORD_ALERT_COOLDOWN_MS=900000
DISCORD_NOTIFY_BRUTE_FORCE=true
DISCORD_NOTIFY_KEY_SCANNING=true
DISCORD_NOTIFY_HIGH_THREAT=true

# Webhook e toggles também podem ser salvos no painel (tabela notification_settings no MySQL).
# O que estiver no banco tem prioridade sobre estas variáveis (URL e flags).
