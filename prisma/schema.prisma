datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum KeyStatus {
  ACTIVE
  USED
  REVOKED
  EXPIRED
}

enum ValidationResult {
  SUCCESS
  INVALID_KEY
  REVOKED
  EXPIRED
  ALREADY_USED
}

model Admin {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  keys Key[]
  logs AccessLog[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  keys Key[]
}

model Key {
  id String @id @default(uuid())

  value String @unique

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdById String
  createdBy   Admin  @relation(fields: [createdById], references: [id])

  customerEmail String?
  customerName  String?

  status KeyStatus @default(ACTIVE)

  isPermanent Boolean @default(false)

  activatedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  usageLogs KeyUsageLog[]
  client    Client?
}

/// Usuário final do cheat (cadastro com key no menu interno)
model Client {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  hwid         String?
  isBanned     Boolean   @default(false)
  expiresAt    DateTime
  loginCount   Int       @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  keyId String @unique
  key   Key    @relation(fields: [keyId], references: [id])

  accessLogs ClientAccessLog[]

  @@index([hwid])
}

/// Tentativas de login/cadastro do cliente (cheat)
model ClientAccessLog {
  id String @id @default(uuid())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  usernameAttempted String
  ipAddress         String
  hwid              String?

  action  String  @default("LOGIN")
  success Boolean
  reason  String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([success, createdAt])
  @@index([ipAddress, createdAt])
}

model KeyUsageLog {
  id String @id @default(uuid())

  keyId String
  key   Key    @relation(fields: [keyId], references: [id])

  ipAddress String
  userAgent String?

  result ValidationResult

  attemptedAt DateTime @default(now())

  @@index([attemptedAt])
  @@index([result, attemptedAt])
  @@index([ipAddress, attemptedAt])
}

model AccessLog {
  id String @id @default(uuid())

  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id])

  usernameAttempted String

  ipAddress String

  success Boolean

  reason String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([success, createdAt])
  @@index([ipAddress, createdAt])
}

/// Config singleton (painel Alcateia) — sobrescreve variáveis de ambiente quando preenchido
model NotificationSettings {
  id String @id

  discordWebhookUrl String? @db.Text

  discordAlertsEnabled Boolean @default(true)

  discordNotifyBruteForce Boolean @default(true)

  discordNotifyKeyScanning Boolean @default(true)

  discordNotifyHighThreat Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}
